# Hymns OBS Backend Environment Variables

# Application
APP_NAME=Hymns OBS API
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./hymns.db

# CORS - Add your frontend URLs here
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# Hymns Data Path (relative to backend folder)
HYMNS_YAML_PATH=../frontend/src/app/data/hymns.yaml
